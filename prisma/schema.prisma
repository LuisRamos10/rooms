generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                          String   @id @default(cuid())
  name                        String
  domain                      String   @unique
  encryptedGoogleServiceAccount String?  @db.Text
  delegatedUser               String?
  settingsJson                String?  @db.Text
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  users    User[]
  rooms    Room[]
  syncLogs SyncLog[]

  @@map("organizations")
}

model User {
  id            String    @id @default(cuid())
  orgId         String?
  googleId      String?   @unique
  email         String    @unique
  emailVerified DateTime?
  name          String?
  avatarUrl     String?
  image         String?
  role          UserRole  @default(MEMBER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  org      Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accounts Account[]
  sessions Session[]
  roomsCreated Room[] @relation("RoomCreator")

  @@index([orgId])
  @@map("users")
}

enum UserRole {
  ADMIN
  MEMBER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Room {
  id                 String     @id @default(cuid())
  orgId              String
  title              String
  meetLink           String?
  calendarEventId    String?
  conferenceRecordId String?
  startTime          DateTime
  endTime            DateTime
  status             RoomStatus @default(SCHEDULED)
  createdById        String?
  syncedAt           DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  org          Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User?            @relation("RoomCreator", fields: [createdById], references: [id])
  participants RoomParticipant[]

  @@unique([orgId, calendarEventId])
  @@index([orgId, status])
  @@index([orgId, startTime])
  @@map("rooms")
}

enum RoomStatus {
  SCHEDULED
  ACTIVE
  ENDED
}

model RoomParticipant {
  id          String    @id @default(cuid())
  roomId      String
  userEmail   String
  displayName String?
  avatarUrl   String?
  joinTime    DateTime?
  leaveTime   DateTime?
  isActive    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, isActive])
  @@index([userEmail])
  @@map("room_participants")
}

model SyncLog {
  id           String     @id @default(cuid())
  orgId        String
  syncType     SyncType
  status       SyncStatus
  errorMessage String?    @db.Text
  startedAt    DateTime   @default(now())
  completedAt  DateTime?

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, syncType])
  @@map("sync_logs")
}

enum SyncType {
  CALENDAR
  MEET
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
}
